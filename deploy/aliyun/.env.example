# Required
MYSQL_ROOT_PASSWORD=change-me

# Optional (后台登录账号)
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=admin123

# Optional JVM memory flags
# JAVA_TOOL_OPTIONS=-Xms128m -Xmx512m

# Optional: allow fixed code login for specific phones (comma-separated).
# NOTE: only for testing; production should integrate real SMS.
# APP_AUTH_FIXED_CODE_WHITELIST_PHONES=13900000000,13800000000

# Optional: public base URL used for notary file uploads (must be internet-accessible).
# APP_PUBLIC_BASE_URL=http://47.120.27.110:8088

# Optional: where to store uploaded files (host volume is ./data/uploads)
# APP_UPLOAD_DIR=/app/uploads

# Optional: Juzheng (notary) config
# JUZHENG_BASE_URL=https://test.gz.51juzheng.cn
# JUZHENG_CLIENT_ID=
# JUZHENG_CLIENT_SECRET=
# JUZHENG_PUBLIC_KEY=
# JUZHENG_PRIVATE_KEY=
# JUZHENG_COMPANY_NAME=
# JUZHENG_COMPANY_CERT_NO=
# JUZHENG_COMPANY_ADDRESS=
# JUZHENG_LEGAL_NAME=
# JUZHENG_LEGAL_CERT_NO=
# JUZHENG_LEGAL_PHONE=
# JUZHENG_COMPANY_TYPE=30
# JUZHENG_CALLBACK_URL=

# Optional: Asign (e-sign) config
# ASIGN_BASE_URL=https://oapi.asign.cn
# ASIGN_APP_ID=
# ASIGN_PRIVATE_KEY=
# ASIGN_PUBLIC_KEY=
# ASIGN_TEMPLATE_NO=
# ASIGN_TEMPLATE_FILL_JSON=
# ASIGN_COMPANY_ACCOUNT=
# ASIGN_COMPANY_NAME=成都华兴租赁科技有限公司
# ASIGN_COMPANY_CERT_NO=91510104MAG00BQP6G
# ASIGN_LEGAL_NAME=杨浩
# ASIGN_LEGAL_CERT_NO=513722199302261573
# ASIGN_LEGAL_PHONE=17502847226
# ASIGN_COMPANY_MOBILE=17502847226
# ASIGN_COMPANY_CONTACT_NAME=杨浩
# ASIGN_COMPANY_CONTACT_ID_CARD=513722199302261573
# ASIGN_SIGN_ORDER=1
# ASIGN_COMPANY_SIGN_TYPE=3
# ASIGN_USER_SIGN_TYPE=3
# ASIGN_COMPANY_SIGN_KEY=
# ASIGN_USER_SIGN_KEY=
# ASIGN_COMPANY_SIGN_STRATEGY_JSON=
# ASIGN_USER_SIGN_STRATEGY_JSON=
# ASIGN_NOTIFY_URL=http://47.120.27.110:8088/api/callbacks/asign/contract
# ASIGN_CALLBACK_URL=http://47.120.27.110:8088/api/callbacks/asign/contract
# ASIGN_USER_NOTIFY_URL=
# ASIGN_AUTH_NOTIFY_URL=http://47.120.27.110:8088/api/callbacks/asign/auth
# ASIGN_AUTH_REDIRECT_URL=
# ASIGN_REDIRECT_URL=
# ASIGN_USE_STRANGER=false
# ASIGN_SIGN_ATTACH_NO=1
# ASIGN_SIGN_LOCATION_MODE=4

# Optional: Docker image registries (use mirrors if docker.io is slow/blocked)
# EVLEASE_MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.0
# EVLEASE_NGINX_IMAGE=docker.m.daocloud.io/library/nginx:1.25-alpine
# EVLEASE_JRE_IMAGE=docker.m.daocloud.io/library/eclipse-temurin:17-jre
